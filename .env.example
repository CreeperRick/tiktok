# ── DISCORD BOT CONFIGURATION ──────────────────────────────────────────────────
# Your Discord Bot Token (Get this from the Discord Developer Portal: https://discord.com/developers/applications)
DISCORD_TOKEN=your_discord_bot_token_here

# ── SPOTIFY API CONFIGURATION (OPTIONAL) ──────────────────────────────────────
# Required only if you want to use Spotify search or load Spotify playlists.
# Generate these at: https://developer.spotify.com/dashboard
SPOTIFY_CLIENT_ID=your_spotify_client_id_here
SPOTIFY_CLIENT_SECRET=your_spotify_client_secret_here
